<!--
  Save as: android/app/src/main/res/xml/network_security_config.xml
  Then reference in AndroidManifest <application ... android:networkSecurityConfig="@xml/network_security_config">
-->
<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
