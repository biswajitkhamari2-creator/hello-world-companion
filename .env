# === Vercel environment variables ===
# Set every one of these in: Vercel → Project → Settings → Environment Variables
# (Production + Preview). After setting them, redeploy.
# This app no longer uses the Lovable runtime — everything calls the upstream
# APIs directly with your own credentials. See docs/google-oauth-setup.md and
# docs/vercel-setup.md for full instructions.

# --- Supabase (client) ---
VITE_SUPABASE_URL=https://ffkyjnswyfeghmfmlapu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_vaeoI4DIfm2VoLkpLiGQUg_zd4IvuHh

# --- Supabase (server) ---
SUPABASE_URL=https://ffkyjnswyfeghmfmlapu.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_vaeoI4DIfm2VoLkpLiGQUg_zd4IvuHh
APP_SUPABASE_SERVICE_ROLE_KEY=

# --- GCP Project ID ---
PROJECT_ID="your-gcp-project-id"

# --- AI (at least one required; Groq preferred, Gemini fallback + OCR) ---
GROQ_API_KEY=
GEMINI_API_KEY="your-gemini-key"

# --- Google Drive (your own OAuth app — see docs/google-oauth-setup.md) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# After setting CLIENT_ID + SECRET on Vercel and redeploying, visit
#   https://<your-vercel-domain>/api/oauth/google/start
# to sign in with the Google account that should own uploads. The callback
# page prints a refresh token — paste it here / into Vercel.
GOOGLE_REFRESH_TOKEN=
# Optional: pin a specific Drive folder; if unset, a "UPSC-Genius-AI" folder is auto-created
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- Telegram (your own bot — from @BotFather) ---
TELEGRAM_BOT_TOKEN=
# Generate any random 32+ char string; must match what you pass to setWebhook
TELEGRAM_WEBHOOK_SECRET=
